# ─────────────────────────────────────────────────────────────
# KLAI Platform — 환경변수 (빌드 스펙 §16)
# 키가 없으면 앱은 시드(목업) 데이터로 그대로 동작한다.
# 키를 채우면 해당 통합만 자동으로 켜진다 (lib/config.ts).
# NEXT_PUBLIC_* 만 클라이언트 노출.
# ─────────────────────────────────────────────────────────────

# 지도 베이스맵 (MapLibre 스타일 JSON URL). 비우면 CARTO 다크매터, 오프라인이면 인라인 폴백.
NEXT_PUBLIC_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json

# 네이버 지도 타일 (소비자 콘텐츠맵을 maplibre→Naver Maps v3로 전환). 비우면 maplibre 폴백.
# console.ncloud.com → AI·NAVER API/Maps → Application 등록 → Web URL에 배포 도메인 등록 → Client ID.
# (주의: 아래 NAVER_CLIENT_ID/SECRET 은 '검색 API'용 — Maps와 별개)
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=

# 네이버 지역검색(매장 카테고리·전화·도로명주소·플레이스 링크). developers.naver.com → 앱등록 → '검색' API. (지도/Maps 키와 별개)
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
# NCP Maps 서버 API(정적지도·지오코딩). console.ncloud.com → Maps → Application → 'API 이용신청'(Static Map/Geocoding). X-NCP-APIGW 헤더, 서버 전용.
NAVER_NCP_KEY_ID=
NAVER_NCP_KEY_SECRET=
# 상세 패널 네이버 정적지도 미니맵 토글 — NCP Static Map 구독 활성화 후 "1"
NEXT_PUBLIC_NAVER_STATICMAP=

# 행정동 경계 소스: sample(가상 동, 기본) | real(scripts/fetch-boundaries.mjs 실행 후)
NEXT_PUBLIC_BOUNDARY_SOURCE=sample
# ADMDONG_URL=                      # 경계 원천(기본 vuski/admdongkor 최신 스냅샷)

# ── Supabase (Auth + DB/PostGIS + Storage) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # 서버 전용 — 웹훅 크레딧 반영·파이프라인 upsert
DATABASE_URL=                       # Prisma (PostGIS 포함 Postgres)

# ── 결제 (PortOne v2) ──
PORTONE_API_SECRET=
PORTONE_STORE_ID=
PORTONE_CHANNEL_KEY=                # 결제창 채널키

# ── 이메일 (Resend, 주간 리포트) ──
RESEND_API_KEY=
RESEND_FROM="KLAI <noreply@yourdomain>"
WEEKLY_RECIPIENTS=                  # 쉼표구분 (실서비스는 Supabase 구독자 조회)

# ── 서버 PDF (Playwright) ──
ENABLE_PDF=0                        # 1 + `npm i -D playwright && npx playwright install chromium`

# ── cron 보호 (/api/cron/* · Vercel Cron 이 Bearer 로 전송) ──
CRON_SECRET=dev-cron-secret-change-me

# ── 지오코딩 (주소/지번 → 좌표·PNU) ──
KAKAO_REST_API_KEY=
# VWORLD_KEY=

# ── 데이터 파이프라인 (Phase 5, pipeline/) ──
# PIPELINE_MOCK=1                   # 0 으로 실데이터
# KOSIS_API_KEY=  G2B_API_KEY=  RONE_API_KEY=  RTMS_API_KEY=
# LOCALDATA_API_KEY=  BIGKINDS_API_KEY=  NAVER_CLIENT_ID=  NAVER_CLIENT_SECRET=

# 유튜브 컨텐츠 신호 (선택) — console.cloud.google.com → YouTube Data API v3 사용설정 → API키
YOUTUBE_API_KEY=
